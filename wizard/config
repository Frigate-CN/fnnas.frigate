            "value": "gateway"
          },
          {
            "label": "Frigate 自带认证",
            "value": "native"
          }
        ],
        "rules": [
          {
            "required": false,
            "message": "请选择认证方式"
          }
        ]
      },
      {
        "type": "tips",
        "helpText": "<strong>飞牛统一网关</strong>：通过飞牛桌面入口访问，使用飞牛账号登录。<br><strong>Frigate 自带认证</strong>：通过 HTTPS 端口（8971）直接访问，使用 Frigate 独立的用户名密码。<br>切换认证方式后应用将自动重启。"
      }
    ]
